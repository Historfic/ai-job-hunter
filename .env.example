# ─── Required ────────────────────────────────────────────────────────────────
# OpenRouter API key — used for job analysis and message generation
# Get yours free at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# ─── LinkedIn Live Scraping ───────────────────────────────────────────────────
# Set to "false" to enable live LinkedIn scraping (default: true = demo mode)
DEMO_MODE=true

# Your LinkedIn li_at session cookie — grab it from browser DevTools:
#   DevTools → Application → Cookies → linkedin.com → li_at
LINKEDIN_SESSION_COOKIE=

# ─── Email Notifications (optional) ──────────────────────────────────────────
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
TO_EMAIL=your@gmail.com
